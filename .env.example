# Public DNS name pointing at this server. Do not include a scheme or path.
COPE_DOMAIN=cope.example.com


# Database credentials live in secrets/db_password. Do not put the password here.

# Control-plane sizing defaults for a server with at least 4GB RAM.
COPE_POSTGRES_MAX_CONNECTIONS=300
COPE_POSTGRES_SHARED_BUFFERS=512MB
COPE_POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
COPE_POSTGRES_MAX_WAL_SIZE=4GB
COPE_WORKER_GAME_THREADS=2048

# Maximum uploaded opening-book size in bytes (64 MiB).
COPE_OPENING_IMPORT_MAX_BYTES=67108864

# Maximum uploaded engine binary size (1 GiB). Binaries live in the persistent
# engine-binaries Docker volume on the main server.
COPE_ENGINE_BINARY_MAX_BYTES=1073741824
